#!/usr/bin/env python3
from __future__ import annotations

import os
import subprocess
from typing import NamedTuple
from typing import Sequence


class Gem(NamedTuple):
    name: str
    version: str

    @property
    def dirname(self) -> str:
        return f"{self.name}-{self.version}"


HERE = os.path.abspath(os.path.dirname(__file__))
CACHE_DIR = os.path.join(
    os.getenv("XDG_CACHE_DIR", os.path.expanduser("~/.cache")),
    "workstation",
)

GEMS = frozenset((
    Gem("puppet", "7.23.0"),
    Gem("r10k", "3.15.4"),
))


def main(argv: Sequence[str] | None = None) -> int:
    gems_dir = os.path.join(CACHE_DIR, "gems")

    os.environ["GEM_HOME"] = gems_dir
    os.environ["PATH"] = (
        os.path.join(gems_dir, "bin")
        + os.pathsep
        + os.getenv("PATH", "")
    )
    for gem in GEMS:
        if not os.path.exists(os.path.join(gems_dir, "gems", gem.dirname)):
            subprocess.run(
                (
                    "gem",
                    "install", gem.name,
                    "--version", gem.version,
                    "--no-document",
                ),
                check=True,
            )

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
